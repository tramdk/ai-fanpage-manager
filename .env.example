# DATABASE_URL: Prisma connection string
# Cho SQLite: "file:./dev.db"
# Cho Postgres: "postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DATABASE_URL="file:./dev.db"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"


# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ROOT ADMIN CREDENTIALS
ADMIN_EMAIL="admin@floral.com"
ADMIN_PASSWORD="admin123"

# CLOUDINARY CONFIGURATION (Image Storage)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# STOCK PHOTO API KEYS (Optional but recommended for high-quality search)
UNSPLASH_ACCESS_KEY=""
PEXELS_API_KEY=""

# DOCKER DATABASE CONFIGURATION (For Postgres if using Docker)
DB_USER=admin
DB_PASSWORD=admin_password
DB_NAME=fanpage_ai_manager

# SMTP CONFIGURATION (For email features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
