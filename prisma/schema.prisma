generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  password          String
  name              String?
  role                  String        @default("user")
  isActive              Boolean       @default(false)
  requirePasswordChange Boolean       @default(false)
  facebookAppId         String?       // Deprecated: legacy support
  facebookAppSecret String?       // Deprecated: legacy support
  createdAt         DateTime      @default(now())
  facebookApps      FacebookApp[]
  fanpages          Fanpage[]
  schedules         Schedule[]
  posts             Post[]
  topics            Topic[]
  workflows         Workflow[]
}

model FacebookApp {
  id        String    @id @default(uuid())
  appId     String
  appSecret String
  name      String?
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  fanpages  Fanpage[]
  createdAt DateTime  @default(now())
}

model Fanpage {
  id            String       @id @default(uuid())
  pageId        String       @unique
  name          String
  accessToken   String
  status        String       @default("active")
  connectedAt   DateTime     @default(now())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  facebookAppId String?
  facebookApp   FacebookApp? @relation(fields: [facebookAppId], references: [id])
  schedules     Schedule[]
  posts         Post[]
}

model Schedule {
  id             String    @id @default(uuid())
  topic          String
  time           String
  advancedPrompt String?
  runCount       Int       @default(1)
  status         String    @default("active")
  fanpageId      String
  fanpage        Fanpage   @relation(fields: [fanpageId], references: [pageId])
  workflowId     String?
  workflow       Workflow? @relation(fields: [workflowId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  createdAt      DateTime  @default(now())
  posts          Post[]

  @@index([userId])
  @@index([fanpageId])
}

model Post {
  id          String    @id @default(uuid())
  topic       String
  content     String
  imageUrl    String?
  fanpageId   String?
  fanpage     Fanpage?  @relation(fields: [fanpageId], references: [pageId])
  scheduleId  String?
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])
  status      String    @default("published")
  orderIndex  Int       @default(0)
  error       String?
  fbPostId    String?   // External Facebook Post ID for tracking
  videoId     String?   // External AutoReels Video ID for tracking
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([fanpageId])
  @@index([status])
}

model Topic {
  id          String   @id @default(uuid())
  name        String
  keywords    String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Workflow {
  id          String     @id @default(uuid())
  name        String
  description String?
  status      String     @default("active")
  nodesData   String     @default("[]") // JSON representation of nodes
  edgesData   String     @default("[]") // JSON representation of edges
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  schedules   Schedule[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model Media {
  id        String   @id @default(uuid())
  name      String
  url       String
  hash      String   @unique // MD5 hash of file content to prevent duplicates
  size      Int
  type      String
  userId    String?
  createdAt DateTime @default(now())

  @@index([hash])
}

model VideoQueue {
  id        String   @id @default(uuid())
  postId    String   @unique
  videoId   String
  status    String   @default("processing")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
